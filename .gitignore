# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.venv*/
.env
.env.*

# Packaging / build
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Testing / coverage
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
.cache/
coverage.xml
*.cover
*.py,cover
hypothesis/
.hypothesis/
htmlcov/

# Type checking / static analysis
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Logs / temp / editors
*.log
*.tmp
*.swp
*.swo

# macOS cruft
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# VS Code: ignore most files but keep settings you actually want in repo
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Project-specific: keep big media out of git by default
music/*
!music/.gitkeep

# If you accidentally put audio elsewhere, ignore common formats
# (Comment these out if you decide to track audio with Git LFS)
*.mp3
*.wav
*.ogg
